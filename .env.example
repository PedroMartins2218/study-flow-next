# Copie este arquivo para .env.local e preencha com valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore padrão do Next.js).

# --- Firebase client (públicas, seguras para expor no navegador) ---
# Pegue em: Firebase Console > Configurações do projeto > Seus apps > Web
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (SECRETAS — usadas só no servidor, fase 2/3) ---
# Gere em: Firebase Console > Configurações do projeto > Contas de serviço > Gerar nova chave privada
# Copie os valores do JSON gerado (não cole o arquivo JSON inteiro no repositório).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Kirvano (pagamento/assinatura) ---
# Link de checkout do plano, mostrado na tela /assinatura (pública, pode expor).
NEXT_PUBLIC_KIRVANO_CHECKOUT_URL=
# Segredo compartilhado para validar que o webhook realmente vem da Kirvano
# (SECRETO — enquanto não confirmarmos o mecanismo real da Kirvano, o
# endpoint funciona sem essa variável, mas loga um aviso).
KIRVANO_WEBHOOK_SECRET=
